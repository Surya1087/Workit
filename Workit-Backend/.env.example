# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# MongoDB Connection String
# For local development: mongodb://localhost:27017/Workit
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Workit
MONGODB_URI=mongodb://localhost:27017/Workit

# Clerk Authentication
# Get these from https://dashboard.clerk.com
# In production (for example on Render), switch this to the matching live Clerk secret key (sk_live_...).
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
